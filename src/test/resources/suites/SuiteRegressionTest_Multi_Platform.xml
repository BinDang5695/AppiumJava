<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >

<suite name="SauceLabs My Demo App mutiple platform" verbose="1" parallel="tests" thread-count="2">

    <test name="Platform Android Test 1">
        <parameter name="platformName" value="Android"/>
        <parameter name="platformVersion" value="15"/>
        <parameter name="deviceName" value="Pixel_8_Pro_API_35"/>
        <parameter name="udid" value="emulator-5554"/>
        <parameter name="automationName" value="UiAutomator2"/>
        <parameter name="appPackage" value="com.saucelabs.mydemoapp.android"/>
        <parameter name="appActivity" value="com.saucelabs.mydemoapp.android.view.activities.SplashActivity"/>
        <parameter name="noReset" value="false"/>
        <parameter name="fullReset" value="false"/>
        <parameter name="autoGrantPermissions" value="true"/>
        <parameter name="host" value="127.0.0.1"/>
        <parameter name="port" value="4723"/>
        <parameter name="systemPort" value="8201"/>
        <classes>
            <class name="testcases.SauceLabsApp.Payment"/>
        </classes>
    </test>

